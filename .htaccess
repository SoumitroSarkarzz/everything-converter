# Enable GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Set proper cache headers
<IfModule mod_expires.c>
    ExpiresActive On
    
    # HTML files - no cache (or short cache)
    ExpiresByType text/html "access plus 1 hour"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/json "access plus 1 year"
    
    # Images
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Enable browser caching
<IfModule mod_headers.c>
    Header set Cache-Control "max-age=31536000, public" "expr=%{SERVER_PORT} = 443"
    Header set Cache-Control "max-age=31536000, public" "expr=%{CONTENT_TYPE} =~ m#(css|javascript|json|svg)#"
</IfModule>

# Rewrite rules for SPA
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Skip if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite to index.html for SPA
    RewriteRule ^(.*)$ index.html [QSA,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Feature Policy
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Character encoding
AddDefaultCharset UTF-8

# Remove ETags
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None
